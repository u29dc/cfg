{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["DOM", "DOM.Iterable", "ESNext"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"resolveJsonModule": true,
		"types": ["bun"],
		"strict": true,
		"alwaysStrict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitAny": true,
		"noImplicitReturns": true,
		"noImplicitThis": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"allowUnreachableCode": false,
		"noFallthroughCasesInSwitch": true,
		"exactOptionalPropertyTypes": true,
		"noImplicitOverride": true,
		"noPropertyAccessFromIndexSignature": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"noEmit": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"paths": {
			"@cfg/core": ["./packages/core/src/index.ts"],
			"@cfg/core/*": ["./packages/core/src/*"],
			"@cfg/vanilla": ["./packages/vanilla/src/index.ts"],
			"@cfg/vanilla/*": ["./packages/vanilla/src/*"],
			"@u29dc/cfg-core": ["./packages/core/src/index.ts"],
			"@u29dc/cfg-core/*": ["./packages/core/src/*"],
			"@u29dc/cfg-vanilla": ["./packages/vanilla/src/index.ts"],
			"@u29dc/cfg-vanilla/*": ["./packages/vanilla/src/*"],
			"cfg": ["./packages/vanilla/src/index.ts"],
			"cfg/styles.css": ["./packages/vanilla/src/styles/cfg.css"]
		}
	},
	"include": ["packages/**/*", "tests/**/*", "demo/**/*", "scripts/**/*", "playwright.config.ts", "vite.config.ts"],
	"exclude": ["node_modules", "build", ".tmp", ".archive"]
}
