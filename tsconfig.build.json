{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"declaration": true,
		"declarationMap": false,
		"emitDeclarationOnly": true,
		"declarationDir": "dist/types",
		"noEmit": false,
		"rootDir": "packages",
		"stripInternal": true
	},
	"include": ["packages/core/src/**/*", "packages/vanilla/src/**/*"]
}
