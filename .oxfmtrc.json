{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"arrowParens": "always",
	"endOfLine": "lf",
	"ignorePatterns": ["dist", "demo-dist", "node_modules", ".tmp", "artifacts", ".clawpatch", ".git"],
	"insertFinalNewline": true,
	"printWidth": 200,
	"proseWrap": "preserve",
	"quoteProps": "as-needed",
	"semi": true,
	"singleQuote": true,
	"sortImports": true,
	"sortPackageJson": false,
	"tabWidth": 4,
	"trailingComma": "all",
	"useTabs": true
}
